# Copy to .env.local and fill in from your Supabase project:
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Canonical site URL (used for sitemap/SEO)
NEXT_PUBLIC_SITE_URL=https://gray-content-studio.vercel.app
